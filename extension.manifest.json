{
  "name": "cpanel-whm-manager",
  "slug": "cpanel-whm-manager",
  "displayName": "cPanel & WHM Manager",
  "version": "1.0.0",
  "description": "Tenant extension to manage WHM/cPanel hosting servers: multi-server connections, encrypted multi-token storage, accounts, metrics, email, domains, databases, FTP, and an SFTP deployment engine. This release ships Server Connections + Multi-Token (encrypted); other modules are registered but return NOT_IMPLEMENTED.",
  "moduleType": "tenant_extension",
  "runtime": "node",
  "language": "typescript",
  "trustLevel": "verified",
  "frontend": {
    "enabled": true,
    "appUrl": "https://hosting.relationai.com.tr/ui",
    "routes": [
      {
        "path": "/dashboard/extensions/hosting-control",
        "label": "Hosting Control",
        "icon": "Server",
        "requiredPermissions": ["hosting_control.view"]
      }
    ],
    "views": [
      {
        "key": "servers",
        "title": "Sunucular",
        "permission": "hosting_control.servers.view",
        "data": { "method": "GET", "path": "api/extensions/cpanel-whm-manager/servers", "itemsKey": "items" },
        "columns": [
          { "key": "name", "label": "Ad" },
          { "key": "hostname", "label": "Host" },
          { "key": "port", "label": "Port", "type": "number" },
          { "key": "status", "label": "Durum", "type": "badge" },
          { "key": "verifySsl", "label": "SSL", "type": "boolean" },
          { "key": "tokenCount", "label": "Token", "type": "number" },
          { "key": "lastCheckedAt", "label": "Son kontrol", "type": "date" }
        ],
        "actions": [
          {
            "key": "create",
            "label": "Sunucu ekle",
            "method": "POST",
            "path": "api/extensions/cpanel-whm-manager/servers",
            "scope": "collection",
            "fields": [
              { "name": "name", "label": "Ad", "required": true },
              { "name": "hostname", "label": "Host (whm.example.com)", "required": true },
              { "name": "port", "label": "Port (2087)", "type": "number" },
              { "name": "verifySsl", "label": "SSL doğrula", "type": "boolean" },
              { "name": "notes", "label": "Not" }
            ]
          },
          {
            "key": "add_token",
            "label": "Token ekle",
            "method": "POST",
            "path": "api/extensions/cpanel-whm-manager/servers/{id}/tokens",
            "scope": "row",
            "fields": [
              { "name": "label", "label": "Etiket", "required": true },
              { "name": "whmUser", "label": "WHM kullanıcı (root)", "required": true },
              { "name": "token", "label": "API token", "required": true, "secret": true }
            ]
          },
          {
            "key": "test",
            "label": "Test",
            "method": "POST",
            "path": "api/extensions/cpanel-whm-manager/servers/{id}/test-connection",
            "scope": "row"
          },
          {
            "key": "sync",
            "label": "Senkronize et",
            "method": "POST",
            "path": "api/extensions/cpanel-whm-manager/servers/{id}/sync",
            "scope": "row"
          },
          {
            "key": "delete",
            "label": "Sil",
            "method": "DELETE",
            "path": "api/extensions/cpanel-whm-manager/servers/{id}",
            "scope": "row",
            "danger": true,
            "confirm": "Sunucu ve tokenları silinsin mi?"
          }
        ]
      },
      {
        "key": "accounts",
        "title": "Hesaplar",
        "permission": "hosting_control.accounts.view",
        "data": { "method": "GET", "path": "api/extensions/cpanel-whm-manager/accounts", "itemsKey": "items" },
        "columns": [
          { "key": "cpanelUser", "label": "Kullanıcı" },
          { "key": "domain", "label": "Alan adı" },
          { "key": "plan", "label": "Paket" },
          { "key": "diskUsedMb", "label": "Disk (MB)", "type": "number" },
          { "key": "suspended", "label": "Askıda", "type": "boolean" },
          { "key": "lastSyncedAt", "label": "Son senkron", "type": "date" }
        ],
        "actions": [
          {
            "key": "refresh",
            "label": "Yenile",
            "method": "POST",
            "path": "api/extensions/cpanel-whm-manager/accounts/{id}/refresh",
            "scope": "row"
          }
        ],
        "detail": {
          "title": "Hesap detayı",
          "idKey": "id",
          "sections": [
            {
              "key": "metrics",
              "title": "Metrikler",
              "type": "fields",
              "permission": "hosting_control.metrics.view",
              "data": { "method": "GET", "path": "api/extensions/cpanel-whm-manager/accounts/{id}/metrics" },
              "fields": [
                { "key": "diskUsedMb", "label": "Disk kullanılan (MB)", "type": "number" },
                { "key": "diskLimitMb", "label": "Disk limit (MB)", "type": "number" },
                { "key": "bandwidthUsedMb", "label": "Bant genişliği (MB)", "type": "number" },
                { "key": "emailAccounts", "label": "E-posta hesabı", "type": "number" },
                { "key": "databases", "label": "Veritabanı", "type": "number" },
                { "key": "addonDomains", "label": "Addon domain", "type": "number" },
                { "key": "subdomains", "label": "Subdomain", "type": "number" },
                { "key": "phpVersion", "label": "PHP sürümü" },
                { "key": "suspended", "label": "Askıda", "type": "boolean" }
              ]
            },
            {
              "key": "emails",
              "title": "E-posta hesapları",
              "type": "table",
              "permission": "hosting_control.email.view",
              "data": { "method": "GET", "path": "api/extensions/cpanel-whm-manager/accounts/{id}/email-accounts" },
              "columns": [
                { "key": "email", "label": "Adres" },
                { "key": "quotaMb", "label": "Kota (MB)", "type": "number" },
                { "key": "usedMb", "label": "Kullanılan (MB)", "type": "number" },
                { "key": "suspended", "label": "Askıda", "type": "boolean" }
              ],
              "actions": [
                {
                  "key": "create",
                  "label": "E-posta ekle",
                  "method": "POST",
                  "path": "api/extensions/cpanel-whm-manager/accounts/{id}/email-accounts",
                  "scope": "collection",
                  "permission": "hosting_control.email.manage",
                  "fields": [
                    { "name": "user", "label": "Kullanıcı", "required": true },
                    { "name": "domain", "label": "Domain", "required": true },
                    { "name": "password", "label": "Parola", "required": true, "secret": true },
                    { "name": "quotaMb", "label": "Kota (MB, 0=sınırsız)", "type": "number" }
                  ]
                },
                {
                  "key": "delete",
                  "label": "Sil",
                  "method": "DELETE",
                  "path": "api/extensions/cpanel-whm-manager/accounts/{id}/email-accounts/{rowId}",
                  "scope": "row",
                  "rowKey": "email",
                  "permission": "hosting_control.email.manage",
                  "danger": true,
                  "confirm": "E-posta hesabı silinsin mi?"
                }
              ]
            },
            {
              "key": "domains",
              "title": "Alan adları",
              "type": "table",
              "permission": "hosting_control.domains.view",
              "data": { "method": "GET", "path": "api/extensions/cpanel-whm-manager/accounts/{id}/domains" },
              "columns": [
                { "key": "domain", "label": "Domain" },
                { "key": "type", "label": "Tip", "type": "badge" },
                { "key": "sslStatus", "label": "SSL", "type": "badge" }
              ],
              "actions": [
                {
                  "key": "autossl",
                  "label": "AutoSSL çalıştır",
                  "method": "POST",
                  "path": "api/extensions/cpanel-whm-manager/accounts/{id}/domains/autossl",
                  "scope": "collection",
                  "permission": "hosting_control.domains.manage"
                }
              ]
            },
            {
              "key": "databases",
              "title": "Veritabanları",
              "type": "table",
              "permission": "hosting_control.databases.view",
              "data": { "method": "GET", "path": "api/extensions/cpanel-whm-manager/accounts/{id}/databases", "itemsKey": "databases" },
              "columns": [
                { "key": "name", "label": "Ad" },
                { "key": "users", "label": "Kullanıcılar" },
                { "key": "sizeMb", "label": "Boyut (MB)", "type": "number" }
              ],
              "actions": [
                {
                  "key": "create",
                  "label": "Veritabanı oluştur",
                  "method": "POST",
                  "path": "api/extensions/cpanel-whm-manager/accounts/{id}/databases",
                  "scope": "collection",
                  "permission": "hosting_control.databases.manage",
                  "fields": [ { "name": "name", "label": "Ad", "required": true } ]
                },
                {
                  "key": "create_user",
                  "label": "Kullanıcı oluştur",
                  "method": "POST",
                  "path": "api/extensions/cpanel-whm-manager/accounts/{id}/database-users",
                  "scope": "collection",
                  "permission": "hosting_control.databases.manage",
                  "fields": [
                    { "name": "name", "label": "Kullanıcı", "required": true },
                    { "name": "password", "label": "Parola", "required": true, "secret": true }
                  ]
                },
                {
                  "key": "delete",
                  "label": "Sil",
                  "method": "DELETE",
                  "path": "api/extensions/cpanel-whm-manager/accounts/{id}/databases/{rowId}?confirm=true",
                  "scope": "row",
                  "rowKey": "name",
                  "permission": "hosting_control.databases.manage",
                  "danger": true,
                  "confirm": "Veritabanı silinsin mi? Bu işlem geri alınamaz."
                }
              ]
            }
          ]
        }
      }
    ]
  },
  "backend": {
    "enabled": true,
    "apiPrefix": "/api/extensions/cpanel-whm-manager",
    "entrypoint": "src/backend/index.ts",
    "baseUrl": "http://cpanel-whm-manager-worker:8080",
    "healthUrl": "http://cpanel-whm-manager-worker:8080/health"
  },
  "database": {
    "enabled": true,
    "prismaSchema": "prisma/extension.prisma",
    "migrationsPath": "prisma/migrations",
    "seed": "prisma/seed.ts",
    "tablePrefix": "ext_hosting_"
  },
  "docker": {
    "enabled": true,
    "dockerfile": "Dockerfile",
    "serviceName": "cpanel-whm-manager-worker",
    "internalPort": 8080,
    "healthcheck": "/health"
  },
  "permissions": [
    "hosting_control.view",
    "hosting_control.admin",
    "hosting_control.servers.view",
    "hosting_control.servers.create",
    "hosting_control.servers.edit",
    "hosting_control.servers.delete",
    "hosting_control.servers.test_connection",
    "hosting_control.tokens.view",
    "hosting_control.tokens.create",
    "hosting_control.tokens.edit",
    "hosting_control.tokens.delete",
    "hosting_control.accounts.view",
    "hosting_control.metrics.view",
    "hosting_control.email.view",
    "hosting_control.email.manage",
    "hosting_control.domains.view",
    "hosting_control.domains.manage",
    "hosting_control.databases.view",
    "hosting_control.databases.manage",
    "hosting_control.ftp.view",
    "hosting_control.ftp.manage",
    "hosting_control.deployments.view",
    "hosting_control.deployments.run",
    "hosting_control.deployments.rollback"
  ],
  "env": [
    {
      "name": "EXT_HOSTING_ENCRYPTION_KEY",
      "required": true,
      "secret": true,
      "description": "Base64-encoded 32-byte key for AES-256-GCM encryption of WHM/cPanel tokens and SFTP credentials."
    },
    {
      "name": "EXT_HOSTING_TENANT_CONTEXT_MODE",
      "required": false,
      "secret": false,
      "description": "authenticated | header. Selects how tenant context is acquired. Default: authenticated."
    },
    {
      "name": "EXT_PLATFORM_JWT_SECRET",
      "required": false,
      "secret": true,
      "description": "Only required when EXT_HOSTING_TENANT_CONTEXT_MODE=header; used to verify the x-ext-token HMAC."
    },
    {
      "name": "EXT_HOSTING_WHM_TIMEOUT_MS",
      "required": false,
      "secret": false,
      "description": "WHM HTTP timeout in ms. Default 15000."
    },
    {
      "name": "EXT_HOSTING_WHM_VERIFY_SSL",
      "required": false,
      "secret": false,
      "description": "true|false default for SSL verification. Per-server override stored on the server row."
    },
    {
      "name": "DATABASE_URL",
      "required": true,
      "secret": true,
      "description": "Tenant-scoped Prisma datasource URL injected by the platform."
    }
  ],
  "jobs": [
    {
      "name": "hosting-control-sync",
      "schedule": "0 */6 * * *",
      "entrypoint": "src/workers/sync.worker.ts",
      "cost": 0
    }
  ],
  "actions": [
    {
      "name": "list_servers",
      "description": "List configured WHM/cPanel server connections (no secrets returned).",
      "method": "GET",
      "path": "api/extensions/cpanel-whm-manager/servers",
      "permission": "hosting_control.servers.view"
    },
    {
      "name": "create_server",
      "description": "Add a WHM/cPanel server connection.",
      "method": "POST",
      "path": "api/extensions/cpanel-whm-manager/servers",
      "permission": "hosting_control.servers.create",
      "params": [
        { "name": "name", "type": "string", "required": true, "description": "Display name for the connection." },
        { "name": "hostname", "type": "string", "required": true, "description": "WHM host, e.g. whm.example.com." },
        { "name": "port", "type": "number", "required": false, "description": "WHM port (default 2087)." },
        { "name": "username", "type": "string", "required": true, "description": "WHM username (e.g. root)." },
        { "name": "verifySsl", "type": "boolean", "required": false, "description": "Verify the server's TLS certificate." }
      ]
    },
    {
      "name": "test_connection",
      "description": "Test connectivity + authentication for a server connection.",
      "method": "POST",
      "path": "api/extensions/cpanel-whm-manager/servers/test",
      "permission": "hosting_control.servers.test_connection",
      "params": [
        { "name": "serverId", "type": "string", "required": true, "description": "Server connection id." }
      ]
    },
    {
      "name": "delete_server",
      "description": "Delete a server connection and its stored tokens.",
      "method": "POST",
      "path": "api/extensions/cpanel-whm-manager/servers/delete",
      "permission": "hosting_control.servers.delete",
      "params": [
        { "name": "serverId", "type": "string", "required": true, "description": "Server connection id." }
      ]
    },
    {
      "name": "list_tokens",
      "description": "List the API tokens stored for a server (token values are never returned).",
      "method": "POST",
      "path": "api/extensions/cpanel-whm-manager/tokens/list",
      "permission": "hosting_control.tokens.view",
      "params": [
        { "name": "serverId", "type": "string", "required": true, "description": "Server connection id." }
      ]
    },
    {
      "name": "create_token",
      "description": "Store an encrypted WHM/cPanel API token for a server.",
      "method": "POST",
      "path": "api/extensions/cpanel-whm-manager/tokens",
      "permission": "hosting_control.tokens.create",
      "params": [
        { "name": "serverId", "type": "string", "required": true, "description": "Server connection id." },
        { "name": "label", "type": "string", "required": true, "description": "Human label for the token." },
        { "name": "token", "type": "string", "required": true, "description": "WHM API token (stored encrypted at rest)." }
      ]
    },
    {
      "name": "delete_token",
      "description": "Delete a stored API token.",
      "method": "POST",
      "path": "api/extensions/cpanel-whm-manager/tokens/delete",
      "permission": "hosting_control.tokens.delete",
      "params": [
        { "name": "tokenId", "type": "string", "required": true, "description": "Stored token id." }
      ]
    }
  ]
}
