# ─── cpanel-whm-manager extension — environment ────────────────────────────
# Copy to `.env` for local/standalone dev. In production these are injected by
# the Relation AI platform (per-tenant secrets arrive as request headers or a
# scoped DSN — see docs/configuration.md). Never commit a real .env.

# Tenant-scoped Prisma datasource. The platform injects a least-privilege DSN
# scoped to ext_hosting_* in the assigned tenant's schema.
DATABASE_URL="postgresql://user:password@localhost:5432/relation_ext?schema=public"

# REQUIRED. Base64-encoded 32-byte key for AES-256-GCM encryption of WHM/cPanel
# tokens and SFTP credentials. Generate with:  openssl rand -base64 32
EXT_HOSTING_ENCRYPTION_KEY=""

# How tenant context is acquired at request time:
#   authenticated  -> trust host-injected req.auth (in-process model, default)
#   header         -> read x-tenant-id/x-user-id and VERIFY x-ext-token HMAC
EXT_HOSTING_TENANT_CONTEXT_MODE="authenticated"

# Only required when EXT_HOSTING_TENANT_CONTEXT_MODE=header. Used to verify the
# x-ext-token HMAC-SHA256 signature injected by the platform gateway.
EXT_PLATFORM_JWT_SECRET=""

# WHM/cPanel HTTP client tuning.
EXT_HOSTING_WHM_TIMEOUT_MS="15000"
EXT_HOSTING_WHM_VERIFY_SSL="true"

# Standalone dev server port (not used in the in-process model).
PORT="11000"
